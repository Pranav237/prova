{
  "expo": {
    "name": "Prova",
    "slug": "prova",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "prova",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0D0B14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.thinkprova.app",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D0B14"
      },
      "package": "com.thinkprova.app"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D0B14"
        }
      ],
      "expo-media-library"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
